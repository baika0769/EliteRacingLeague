{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information"
    }
  },
  "SystemTime": {
    "AllowTimeOverride": true,
    "EnableBackgroundSync": false,
    "SyncIntervalSeconds": 60
  },
  "Database": {
    "AutoMigrateOnStartup": false
  }
}
